APP_NAME=KaamSetu API
APP_ENV=production
BACKEND_URL=https://kaamsetu.onrender.com
FRONTEND_URL=https://kaamsetu.onrender.com
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME?sslmode=require
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://kaamsetu.onrender.com/auth/google/callback
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
MAP_GEOCODER_PROVIDER=nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
CORS_ORIGINS=https://kaamsetu.onrender.com
